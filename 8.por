programa 
{
  funcao inicio()
   {
    cadeia mae = "Tess"
    cadeia filha = "Anna"
    cadeia troca //eu só quis criar isso pra facilitar minha vida, ficou estranho eu sei :(
    
    troca = mae 
    mae = filha
    mae = troca

    escreva ("Anna se tornou " + mae + "\n")
    escreva ("Tess se tornou " + filha)
   }
}
